      const sphereScores = Object.entries(this.scores)
        .filter(([key]) => key !== "neutral")
        .sort((a, b) => b[1] - a[1]);

      return {
        type: "specific",
        top1: sphereScores[0][0],
        top2: sphereScores[1][0],
        scores: this.scores,
