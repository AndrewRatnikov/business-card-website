---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
---

<Layout
  title="Тест: Діагностика впливу ненароджених дітей на життя | Анна Ратнікова"
>
  <Header />
  <main class="pb-10">
    <section class="container mx-auto px-4 py-16">
      <div class="header">
        <h1>Діагностика впливу ненароджених дітей на життя</h1>
        <p>М'яка діагностика можливих зон впливу на різні сфери життя</p>
      </div>

      <div id="app"></div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  :root {
    --bg-gradient: linear-gradient(
      135deg,
      #fef6f0 0%,
      #fff5ed 50%,
      #ffeee3 100%
    );
    --card-bg: rgba(255, 255, 255, 0.85);
    --text-primary: #2d3748;
    --text-secondary: #718096;
    --accent: #d4917b;
    --accent-hover: #c07f68;
    --border: rgba(212, 145, 123, 0.15);
    --shadow: 0 4px 20px rgba(212, 145, 123, 0.12);
  }

  .header {
    text-align: center;
    margin-bottom: 60px;
    animation: fadeInDown 0.8s ease-out;
  }

  .header h1 {
    font-size: 2.5rem;
    margin-bottom: 15px;
    color: var(--text-primary);
    font-family: "Cormorant Garamond", serif;
    font-weight: 300;
    letter-spacing: 0.5px;
  }

  .header p {
    font-size: 1rem;
    color: var(--text-secondary);
    font-weight: 300;
  }

  .card {
    background: var(--card-bg);
    backdrop-filter: blur(10px);
    border-radius: 24px;
    padding: 40px;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    margin-bottom: 30px;
    animation: fadeInUp 0.8s ease-out;
  }

  .progress-bar {
    width: 100%;
    height: 4px;
    background: rgba(212, 145, 123, 0.2);
    border-radius: 4px;
    margin-bottom: 30px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #d4917b, #e8b5a0);
    border-radius: 4px;
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .progress-text {
    text-align: center;
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 15px;
    font-weight: 300;
  }

  .question-breadcrumbs {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 25px;
    flex-wrap: wrap;
  }

  .breadcrumb-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(212, 145, 123, 0.2);
    transition: all 0.3s ease;
    position: relative;
  }

  .breadcrumb-dot.answered {
    background: var(--accent);
  }

  .breadcrumb-dot.current {
    background: var(--accent);
    transform: scale(1.3);
    box-shadow: 0 0 0 3px rgba(212, 145, 123, 0.2);
  }

  .question-container {
    animation: fadeIn 0.5s ease-out;
  }

  .question-title {
    font-size: 1.4rem;
    margin-bottom: 30px;
    color: var(--text-primary);
    line-height: 1.5;
    font-family: "Cormorant Garamond", serif;
    font-weight: 300;
  }

  .options {
    display: grid;
    gap: 15px;
  }

  .option {
    background: white;
    border: 2px solid transparent;
    border-radius: 16px;
    padding: 20px 24px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .option::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(212, 145, 123, 0.1),
      transparent
    );
    transition: left 0.5s ease;
  }

  .option:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212, 145, 123, 0.15);
  }

  .option:hover::before {
    left: 100%;
  }

  .option.selected {
    border-color: var(--accent);
    background: linear-gradient(
      135deg,
      rgba(212, 145, 123, 0.08),
      rgba(232, 181, 160, 0.08)
    );
  }

  .option-label {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .option-radio {
    width: 20px;
    height: 20px;
    border: 2px solid var(--accent);
    border-radius: 50%;
    position: relative;
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .option.selected .option-radio::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    width: 10px;
    height: 10px;
    background: var(--accent);
    border-radius: 50%;
    animation: radioScale 0.3s ease forwards;
  }

  .option-text {
    font-size: 1.05rem;
    line-height: 1.5;
  }

  .btn {
    background: linear-gradient(135deg, var(--accent), var(--accent-hover));
    color: white;
    border: none;
    padding: 16px 40px;
    border-radius: 12px;
    font-size: 1.05rem;
    font-weight: 400;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-block;
    text-decoration: none;
    box-shadow: 0 4px 15px rgba(212, 145, 123, 0.3);
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212, 145, 123, 0.4);
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .btn-secondary {
    background: white;
    color: var(--accent);
    border: 2px solid var(--accent);
    box-shadow: none;
  }

  .btn-secondary:hover {
    background: var(--accent);
    color: white;
  }

  .button-group {
    display: flex;
    justify-content: center;
    gap: 15px;
    margin-top: 30px;
  }

  .results {
    animation: fadeIn 0.8s ease-out;
  }

  .results-intro {
    margin-bottom: 40px;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .results-title {
    font-size: 2rem;
    margin-bottom: 25px;
    text-align: center;
    font-family: "Cormorant Garamond", serif;
    font-weight: 300;
  }

  .results-content {
    margin-bottom: 40px;
  }

  .results-content h3 {
    font-size: 1.5rem;
    margin-bottom: 20px;
    color: var(--accent);
    font-family: "Cormorant Garamond", serif;
    font-weight: 300;
  }

  .results-content p {
    margin-bottom: 15px;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .results-list {
    list-style: none;
    padding-left: 0;
    margin: 20px 0;
  }

  .results-list li {
    padding-left: 25px;
    margin-bottom: 12px;
    position: relative;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .results-list li::before {
    content: "•";
    position: absolute;
    left: 8px;
    color: var(--accent);
    font-size: 1.2rem;
  }

  .chart-container {
    margin: 40px 0;
    padding: 30px;
    background: white;
    border-radius: 20px;
  }

  .chart-title {
    text-align: center;
    font-size: 1.15rem;
    margin-bottom: 30px;
    color: var(--text-secondary);
    font-weight: 300;
  }

  .chart-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 10px;
  }

  .chart-item {
    text-align: center;
  }

  .chart-bar {
    height: 80px;
    background: white;
    border: 2px solid var(--accent);
    border-radius: 12px;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .chart-value {
    font-size: 1.8rem;
    font-weight: 400;
    color: var(--accent);
  }

  .chart-label {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.3;
  }

  .emoji {
    font-size: 1.5rem;
    margin-right: 8px;
  }

  .video-cta {
    background: linear-gradient(
      135deg,
      rgba(212, 145, 123, 0.1),
      rgba(232, 181, 160, 0.1)
    );
    border-radius: 20px;
    padding: 30px;
    text-align: center;
    margin: 40px 0;
  }

  .video-cta h3 {
    font-size: 1.4rem;
    margin-bottom: 20px;
    font-family: "Cormorant Garamond", serif;
    font-weight: 300;
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes radioScale {
    to {
      transform: translate(-50%, -50%) scale(1);
    }
  }

  @media (max-width: 768px) {
    .header h1 {
      font-size: 2rem;
    }

    .card {
      padding: 30px 24px;
    }

    .question-title {
      font-size: 1.2rem;
    }

    .option-text {
      font-size: 1rem;
    }

    .chart-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
    }

    .button-group {
      flex-direction: column;
    }
  }
</style>

<script>
  const questions = [
