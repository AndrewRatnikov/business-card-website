    {label:"🔄 Почати спочатку", action:'restart'},
  ]
};

// ---------- Rendering engine ----------
const messagesEl = document.getElementById('messages');
const scoreBadge = document.getElementById('scoreBadge');
const restartFab = document.getElementById('restartFab');
const statusLine = document.getElementById('statusLine');

function scrollToBottom() {
  messagesEl.scrollTop = messagesEl.scrollHeight + 200;
}

function typingDelay(text) {
  const len = (text || '').length;
  return Math.min(1400, Math.max(500, len * 18));
}

function showTyping() {
  const row = document.createElement('div');
  row.className = 'row in';
  row.innerHTML = `<div class="typing"><span></span><span></span><span></span></div>`;
  messagesEl.appendChild(row);
  scrollToBottom();
  return row;
}

function addSticker(name) {
  return new Promise(resolve => {
    const typingRow = showTyping();
    setTimeout(() => {
      typingRow.remove();
      const row = document.createElement('div');
      row.className = 'row in';
      const img = document.createElement('img');
      img.className = 'sticker-msg';
      img.src = STICKERS[name];
      row.appendChild(img);
      messagesEl.appendChild(row);
      scrollToBottom();
      resolve();
    }, 550);
  });
}

function addCharLine(text) {
  return new Promise(resolve => {
    const typingRow = showTyping();
    setTimeout(() => {
      typingRow.remove();
      const row = document.createElement('div');
      row.className = 'row in';
      row.innerHTML = `<div class="bubble in">${text}</div>`;
      messagesEl.appendChild(row);
      scrollToBottom();
      resolve();
    }, typingDelay(text));
  });
}

function addBotCard(bot) {
  return new Promise(resolve => {
    const typingRow = showTyping();
    setTimeout(() => {
      typingRow.remove();
      const row = document.createElement('div');
      row.className = 'row in';
      const titleHtml = bot.title ? `<div class="bot-title">${bot.title}</div>` : '';
      row.innerHTML = `<div class="bubble bot">${titleHtml}${bot.text.replace(/\n/g,'<br>')}</div>`;
      messagesEl.appendChild(row);
      scrollToBottom();
      resolve();
    }, typingDelay(bot.text) + 200);
  });
}

function addUserChoice(text) {
  const row = document.createElement('div');
  row.className = 'row out';
  row.innerHTML = `<div class="bubble out">${text}</div>`;
  messagesEl.appendChild(row);
  scrollToBottom();
}

function clearButtons() {
  const old = messagesEl.querySelector('.buttons-wrap');
  if (old) old.remove();
}

async function playSequence(seq) {
  for (const item of seq) {
    if (item.sticker) await addSticker(item.sticker);
    else if (item.char) {
      for (const line of item.char) await addCharLine(line);
    }
    else if (item.bot) await addBotCard(item.bot);
  }
}

function renderButtons(buttons) {
  const wrap = document.createElement('div');
  wrap.className = 'buttons-wrap';
  buttons.forEach(b => {
    const btn = document.createElement('button');
    btn.className = 'choice-btn';
    btn.textContent = b.label;
    btn.onclick = () => handleChoice(b);
    wrap.appendChild(btn);
  });
  messagesEl.appendChild(wrap);
  scrollToBottom();
}

async function handleChoice(b) {
  clearButtons();
  addUserChoice(b.label);
  if (typeof b.points === 'number') score += b.points;
  updateScoreBadge();
  scrollToBottom();

  if (b.action === 'restart') { restartAll(); return; }
  if (b.action === 'noop') { return; }

  await goToStep(b.next);
}

async function goToStep(id) {
  let step;
  if (id === 'menu') step = menuStep;
  else if (id === 'final') step = finalStep();
  else if (id === 'outro') step = outroStep;
  else if (id === 's2_final') step = s2FinalStep();
  else if (id === 's2_outro') step = s2OutroStep;
  else step = scenario[id];

  if (id === 'start' || id === 's2_start') {
    score = 0;
    updateScoreBadge();
    scoreBadge.style.display = 'none';
  }
  if (step.showScore || id === 'start' || id === 's2_start') { scoreBadge.style.display = 'block'; }
  await playSequence(step.sequence);
  if (step.buttons) renderButtons(step.buttons);
  if (id === 'outro' || id === 's2_outro') { restartFab.style.display = 'flex'; statusLine.textContent = 'був(-ла) щойно'; }
}

function updateScoreBadge() {
  scoreBadge.textContent = `✅ ${score}/3`;
}

function restartAll() {
  score = 0;
  updateScoreBadge();
  scoreBadge.style.display = 'none';
  restartFab.style.display = 'none';
  statusLine.textContent = 'онлайн';
  messagesEl.innerHTML = '';
  goToStep('menu');
}

restartFab.onclick = restartAll;
document.getElementById('headerAvatar').src = STICKERS.avatar;

// kick off
goToStep('menu');
</script>
